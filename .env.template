# SE-QPT Environment Configuration Template
# Copy this file to .env and fill in the actual values
# NEVER commit the .env file to version control

# ============================================================
# Database Configuration
# ============================================================
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/seqpt_database

# ============================================================
# Flask Configuration
# ============================================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<your-secret-key>
JWT_SECRET_KEY=<your-jwt-secret-key>

# ============================================================
# OpenAI API Configuration
# ============================================================
OPENAI_API_KEY=<your-openai-api-key>

# ============================================================
# Integration Configuration
# ============================================================
DERIK_INTEGRATION_ENABLED=true
COMPETENCY_ASSESSMENT_ENDPOINT=http://localhost:5001/api/assess

# ============================================================
# File Paths (set automatically, override if needed)
# ============================================================
EXCEL_SOURCE_FILE=data/source/excel/Qualifizierungsmodule_Qualifizierungspläne_v4_enUS.xlsx
QUESTIONNAIRES_DIR=data/source/questionnaires
TEMPLATES_DIR=data/source/templates

# ============================================================
# Quality Thresholds
# ============================================================
RAG_QUALITY_THRESHOLD=0.85
COMPETENCY_GAP_THRESHOLD=1.0

# ============================================================
# CORS Origins for Frontend
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# Production Only (DigitalOcean deployment)
# ============================================================
# DATABASE_URL=postgresql://seqpt_admin:<db_password>@db:5432/seqpt_database
# FLASK_ENV=production
# FLASK_DEBUG=0
# CORS_ORIGINS=http://<your-domain>
