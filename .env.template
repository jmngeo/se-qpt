# SE-QPT Environment Configuration Template
# Copy this file to .env and fill in the actual values
# NEVER commit the .env file to version control

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/seqpt_database

# ============================================================
# Flask
# ============================================================
FLASK_APP=run.py
FLASK_DEBUG=1

# Generate strong keys: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<your-secret-key>
JWT_SECRET_KEY=<your-jwt-secret-key>

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=<your-openai-api-key>

# ============================================================
# Production overrides (DigitalOcean deployment)
# ============================================================
# DATABASE_URL=postgresql://seqpt_admin:<db_password>@db:5432/seqpt_database
# FLASK_DEBUG=0
